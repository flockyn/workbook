{
    "name": "flockyn/workbook",
    "description": "A lightweight, memory-efficient PHP library for reading, writing, and streaming spreadsheets.",
    "keywords": [
        "php",
        "spreadshet",
        "excel",
        "csv",
        "import",
        "export",
        "reader",
        "writer",
        "stream"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Candra Sudirman",
            "email": "dev.cndrsdrmn@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "cndrsdrmn/spreadsheet-installer": "^0.1",
        "flockyn/phpflock": "^1.1",
        "symfony/process": "^7.2"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "rector/rector": "^2.1",
        "symfony/var-dumper": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "Flockyn\\Workbook\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "lint": "pint",
        "refactor": "rector",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run",
        "test:types": "phpstan",
        "test:unit": "phpunit",
        "test": [
            "@test:lint",
            "@test:unit",
            "@test:types",
            "@test:refactor"
        ]
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "cndrsdrmn/spreadsheet-installer": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0-dev"
        }
    }
}
